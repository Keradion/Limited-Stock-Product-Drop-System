# Database Connection URL (PostgreSQL)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/limited_stock_drop?schema=public"

# Redis Cloud
REDIS_URL="redis://default:your_password@your-host.db.redis.io:17329"

# Server Port
PORT=3001

# App
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=limited-stock-drop

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="1d"

# Auth
BCRYPT_SALT_ROUNDS=10

# Graceful shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Rate limiting
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_RESERVE_WINDOW_MS=60000
RATE_LIMIT_RESERVE_MAX=3
RATE_LIMIT_CHECKOUT_WINDOW_MS=60000
RATE_LIMIT_CHECKOUT_MAX=5

# Seed
SEED_USER_PASSWORD="password123"
